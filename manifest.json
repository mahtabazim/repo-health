{
  "manifest_version": 3,
  "name": "RepoHealth — Is this GitHub repo alive?",
  "version": "0.1.1",
  "description": "Injects a health badge on GitHub repos: last activity, issue/PR responsiveness, and an alive/stale score — at a glance.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.github.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "RepoHealth"
  }
}
